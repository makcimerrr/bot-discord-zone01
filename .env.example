# Configuration du Bot Discord Zone01
# Copiez ce fichier en .env et remplissez avec vos valeurs

# ===== DISCORD =====
# Token de votre bot Discord (OBLIGATOIRE)
# Obtenir sur : https://discord.com/developers/applications
TOKEN='votre_token_discord_ici'

# ===== API CORESIGNAL / RAPIDAPI =====
# Clés API pour la recherche d'offres d'emploi sur LinkedIn
# Obtenir sur : https://rapidapi.com/
RAPIDAPI_KEY='votre_cle_rapidapi_principale'
RAPIDAPI_KEY2='votre_cle_rapidapi_secondaire'

# ===== QUERIES DE RECHERCHE =====
# Query de recherche pour les alternances/stages
QUERY_INTERNSHIP='Développeur Web Alternance France'

# Query de recherche pour les emplois à temps plein (CDI)
QUERY_FULLTIME='Développeur Full Stack CDI France'

# ===== NOTION (Optionnel) =====
# Token d'intégration Notion
NOTION_TOKEN='votre_token_notion'

# ID de la base de données Notion
NOTION_DATABASE_ID='votre_database_id'

# ===== SERVEUR WEB (commande /connect) =====
# URL publique du serveur web utilisée pour générer les liens de liaison de compte.
# En développement local : http://localhost:8080
# En production : votre domaine ou IP publique, ex. https://bot.example.com
CONNECT_BASE_URL='http://localhost:8080'

# Port sur lequel le serveur web écoute (défaut : 8080)
CONNECT_PORT='8080'
